      "isDeleted": true,
      "boundElements": [],
      "updated": 1776189727334,
      "link": null,
      "locked": false,
      "text": "The ON clause (is_current=true) no longer matches — so NOT MATCHED is true, but change_type snapshot says CHANGED.",
      "fontSize": 14,

      "link": null,
      "locked": false,
      "text": "Intended to insert John's new version. But in the same MERGE pass, John's row was just expired.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Intended to insert John's new version. But in the same MERGE pass, John's row was just expired.",
